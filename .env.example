# Multi-Agent Orchestrator — Environment Template
#
# 1. Copy to .env:  cp .env.example .env
# 2. Fill in at least one API key below.
# 3. Never commit .env to git (it is in .gitignore).
#
# Note: Environment variables (e.g. from shell) override values in .env.

# ============================================================
# API Keys (at least one required for non-mock runs)
# ============================================================

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Claude 4)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google / Gemini (Gemini 1.5 Pro, 2.5 Flash, 2.5 Pro)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenRouter (optional — 100+ models via one key)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ============================================================
# Ragıp Aga — Dış Veri Entegrasyonu
# ============================================================

# TCMB EVDS — Canlı faiz oranı, döviz kuru (ücretsiz, kayıt gerekli)
# Kayıt: https://evds3.tcmb.gov.tr → Profil → API Anahtarı
# Desteklenen seriler: Politika faizi, gecelik faiz, yasal gecikme faizi, USD/EUR kuru
TCMB_API_KEY=

# CollectAPI — Banka mevduat ve ihtiyaç kredi oranları (ücretli, üye olunması gerekli)
# Kayıt: https://collectapi.com → API Anahtarı al
# Kullanım: ragip_rates.py --mevduat  (32 günlük en iyi mevduat)
#           ragip_rates.py --kredi    (ihtiyaç kredisi banka karşılaştırması)
COLLECTAPI_KEY=

# ============================================================
# Testing & development
# ============================================================

# Mock LLM responses (no API calls; for tests / offline)
# Set to 1, true or yes to enable.
LLM_MOCK=false

# API server port (default 5050)
PORT=5050

# ============================================================
# Provider feature flags (optional)
# ============================================================
# Set to 1 to disable a provider (e.g. when key is missing or rate-limited).
# DISABLE_OPENAI=1
# DISABLE_ANTHROPIC=1
# DISABLE_GOOGLE=1
# DISABLE_OPENROUTER=1
